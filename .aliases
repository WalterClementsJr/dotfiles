alias cat="bat"
alias e="nvim"
alias g="git"
alias ls="ls -a --color=auto --group-directories-first"
alias ll="ls -la"
alias ln="ln -v"
alias mkdir="mkdir -p"
alias mv="mv -v"
alias rm="echo Use the full path '/bin/rm', or use trash/gio trash"
alias brm="/bin/rm"
alias cowsay="cowsay -f small -g"
alias def="dict -d gcide"
alias thes="dict -d moby-thesaurus"
alias lzg="lazygit"
alias lzd="lazydocker"

alias reload="exec ${SHELL} -l"

# Pretty print path
alias path='echo $PATH | tr -s ":" "\n"'

alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias -- -="cd -"

# Include custom aliases
[[ -f ~/.aliases.local ]] && source ~/.aliases.local
