set nocp
set encoding=utf-8

syntax on
filetype plugin indent on 

set t_Co=256

set noerrorbells
set novisualbell

set nu rnu
set ruler
set ttyfast

set tabstop=4 softtabstop=4
set shiftwidth=4
set expandtab
set autoindent
set nowrap
set backspace=indent,eol,start
set autoread

set ignorecase
set smartcase
set hlsearch
set showmatch
set incsearch

inoremap jk <Esc>

